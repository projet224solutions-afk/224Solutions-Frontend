# legacy-peer-deps=true
# Ce flag est nécessaire car plusieurs packages dans ce projet ont des
# peer-dependencies conflictuelles (notamment Capacitor v7/v8 avec certains
# plugins, et quelques composants Radix UI avec des versions de React).
# Sans ce flag, npm install échoue avec des erreurs ERESOLVE.
#
# ⚠️ LORS D'UNE MISE À JOUR de dépendances majeures :
#   1. Tenter d'abord : npm install --no-legacy-peer-deps
#   2. Si ERESOLVE → identifier les conflits avec : npm install --dry-run
#   3. Résoudre les conflits de version avant de réactiver legacy-peer-deps
#
legacy-peer-deps=true
